# Example environment configuration for the QTrobot backend.
# Copy this file to `.env` and replace the placeholder values with
# real credentials and URLs for your environment.

# Base Keycloak URL that the backend container uses to talk to Keycloak.
KEYCLOAK_SERVER_URL=http://keycloak:8080/

# Keycloak realm and client configuration.
KEYCLOAK_REALM=qtrobot
KEYCLOAK_CLIENT_ID=qtrobot-realm

# Keycloak admin user used only for admin API access (never commit real values).
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# Optional public URL used by browsers (Swagger UI) to reach Keycloak.
# If omitted, KEYCLOAK_SERVER_URL is used.
KEYCLOAK_PUBLIC_URL=http://localhost:8080/

# Google OAuth client ID used to validate Google ID tokens from the Android app.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional: allow multiple audiences (comma-separated) if your Android app
# uses the Android OAuth client ID as `aud`, or you support both Android + web.
GOOGLE_CLIENT_IDS=your-android-client-id.apps.googleusercontent.com,your-web-client-id.apps.googleusercontent.com

# Secret used to mint short-lived internal app JWTs when exchanging Google tokens.
APP_JWT_SECRET=super-secret-change-me

# Redirect URI for the `/auth/google` Keycloak login helper.
# Must be included in Keycloak client's "Valid redirect URIs".
KEYCLOAK_REDIRECT_URI=http://localhost:8000/auth/callback

# Optional: fallback Keycloak client secret if automatic fetch fails.
KEYCLOAK_CLIENT_SECRET=replace-with-client-secret-or-remove

