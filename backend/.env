# Keycloak Configuration
# Internal URL used inside Docker (backend -> Keycloak container)
KEYCLOAK_SERVER_URL=http://keycloak:8080/
KEYCLOAK_REALM=qtrobot
KEYCLOAK_CLIENT_ID=qtrobot-realm
# KEYCLOAK_CLIENT_SECRET will be fetched automatically from Keycloak

# Admin credentials used for Keycloak Admin REST API access
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Public URL used by browser / Swagger (host machine -> Keycloak)
KEYCLOAK_PUBLIC_URL=http://localhost:8080/

# Google Sign-In configuration for backend token exchange
GOOGLE_CLIENT_ID=22218075647-356a5vkjprhrvlt5f5a0hnbim57lgmqg.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=22218075647-s72jsa05bddrn15h9s97ksgk5nae86k6.apps.googleusercontent.com,22218075647-356a5vkjprhrvlt5f5a0hnbim57lgmqg.apps.googleusercontent.com
APP_JWT_SECRET=change-me-to-a-long-random-secret

# Used by /auth/google redirect flow (Keycloak standard login)
KEYCLOAK_REDIRECT_URI=http://localhost:8000/auth/callback

# Required for /auth/callback token exchange (confidential Keycloak client)
KEYCLOAK_CLIENT_SECRET=30PmR6VHJyH1raxmfnEBLHITZQdOUigc

# (Optional) When exporting/importing the realm you can substitute the
# Google client credentials with environment variables. The backend
# itself does not read these values.
#KEYCLOAK_GOOGLE_CLIENT_ID=
#KEYCLOAK_GOOGLE_CLIENT_SECRET=