<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/page_border_background">

    <ImageView
        android:id="@+id/qtrobot_image"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:src="@drawable/qtrobot"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/welcome_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.2" /> <!-- Wider margins for tablet -->

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.8" />

    <androidx.cardview.widget.CardView
        android:id="@+id/welcome_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/qtCardBackground"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline_end"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintTop_toBottomOf="@id/qtrobot_image">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">


            <Button
                android:id="@+id/btn_email_login"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:backgroundTint="@android:color/white"
                android:text="Sign in with Email"
                android:textAllCaps="false"
                android:textColor="?attr/qtPrimary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:cornerRadius="15dp" />


            <com.google.android.gms.common.SignInButton
                android:id="@+id/googleSignInButton"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@android:color/white"
                android:text="Sign in with Google"
                android:textAllCaps="false"
                android:textColor="#757575"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="15dp"
                app:icon="@mipmap/ic_google_logo"
                app:iconGravity="textStart"
                app:iconSize="48dp"
                app:iconPadding="12dp"
                app:iconTint="@null"
                app:strokeColor="#DADCE0"
                app:strokeWidth="1dp" />

            <!-- Guest -->
            <Button
                android:id="@+id/btn_try_app"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="?attr/qtContainer"
                android:text="Try the App"
                android:textAllCaps="false"
                android:textColor="?attr/qtPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="15dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>