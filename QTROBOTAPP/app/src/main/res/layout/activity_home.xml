<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/page_border_background"
    tools:context=".HomeActivity">

    <ImageButton
        android:id="@+id/upcoming_appointment_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/solid_blue_rounded"
        android:scaleType="fitCenter"
        android:padding="14dp"
        app:tint="@android:color/white"
        android:src="@drawable/upcoming_appoint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.18"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_max="100dp" />

    <ImageButton
        android:id="@+id/qr_code_button"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/solid_blue_rounded"
        android:contentDescription="Open QR Code Page"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/qr_code_page_icon"
        app:layout_constraintEnd_toStartOf="@+id/app_settings_top"
        app:layout_constraintStart_toEndOf="@+id/upcoming_appointment_top"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white"
        app:layout_constraintWidth_percent="0.20"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_max="110dp" />

    <ImageButton
        android:id="@+id/app_settings_top"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/solid_blue_rounded"
        android:scaleType="fitCenter"
        android:padding="14dp"
        app:tint="@android:color/white"
        android:src="@drawable/app_settings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.18"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_max="100dp" />

    <TextView
        android:id="@+id/greeting_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="?attr/qtPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/qr_code_button"
        tools:text="Hi, Alice!"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/qtrobot_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/qtrobot"
        app:layout_constraintBottom_toTopOf="@+id/dentist_helper_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/greeting_text" />

    <TextView
        android:id="@+id/dentist_helper_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/solid_blue_rounded"
        android:paddingStart="40dp"
        android:paddingTop="12dp"
        android:paddingEnd="40dp"
        android:paddingBottom="12dp"
        android:text="@string/dentist_helper"
        android:textColor="@android:color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/qtrobot_title_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/qtrobot_title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/qtrobot_title"
        android:textColor="?attr/qtPrimary"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation_manual"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/bottom_navigation_manual"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHeight_percent="0.15">

        <ImageButton
            android:id="@+id/navigation_learn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:background="@drawable/solid_blue_rounded"
            android:scaleType="fitCenter"
            android:padding="24dp"
            app:tint="@android:color/white"
            android:src="@drawable/qtrobot_learn" />

        <ImageButton
            android:id="@+id/navigation_daily_brush"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:background="@drawable/solid_blue_rounded"
            android:scaleType="fitCenter"
            android:padding="24dp"
            app:tint="@android:color/white"
            android:src="@drawable/dailybrush" />

        <ImageButton
            android:id="@+id/navigation_brush_time"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:background="@drawable/solid_blue_rounded"
            android:scaleType="fitCenter"
            android:padding="24dp"
            app:tint="@android:color/white"
            android:src="@drawable/toothbrush" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
