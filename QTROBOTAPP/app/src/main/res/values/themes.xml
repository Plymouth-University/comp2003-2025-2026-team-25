<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.QTrobot" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">?attr/qtPrimary</item>
        <item name="colorPrimary">?attr/qtPrimary</item>
        <item name="colorOnPrimary">?attr/qtOnPrimary</item>
        <item name="colorPrimaryContainer">?attr/qtContainer</item>

        <!-- Global Material button + card styles -->
        <item name="materialButtonStyle">@style/Widget.QTrobot.Button.Primary</item>
        <item name="cardViewStyle">@style/Widget.QTrobot.Card</item>
    </style>

    <style name="Theme_App_Blue" parent="Base.Theme.QTrobot">
        <item name="qtPrimary">@color/primary_blue</item>
        <item name="qtContainer">@color/container_blue</item>
        <item name="qtOnPrimary">@color/white</item>
        <item name="qtCardBackground">@color/primary_blue</item>
        <item name="qtAccent">@color/primary_blue</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme_App_Pink" parent="Base.Theme.QTrobot">
        <item name="qtPrimary">@color/primary_pink</item>
        <item name="qtContainer">@color/container_pink</item>
        <item name="qtOnPrimary">@color/on_primary_pink</item>
        <item name="qtCardBackground">@color/primary_pink</item>
        <item name="qtAccent">@color/primary_pink</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.QTrobot" parent="Theme_App_Blue" />
</resources>