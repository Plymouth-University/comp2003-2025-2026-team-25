<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.QTrobot" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">?attr/qtPrimary</item>
        <item name="colorPrimary">?attr/qtPrimary</item>
        <item name="colorOnPrimary">?attr/qtOnPrimary</item>
        <item name="colorPrimaryContainer">?attr/qtContainer</item>
        <item name="android:datePickerDialogTheme">@style/CustomDatePickerDialog</item>
    </style>

    <style name="Theme_App_Blue" parent="Base.Theme.QTrobot">
        <item name="qtPrimary">@color/primary_blue</item>
        <item name="qtContainer">@color/container_blue</item>
        <item name="qtOnPrimary">@color/white</item>
        <item name="qtCardBackground">@color/primary_blue</item>
        <item name="qtAccent">@color/primary_blue</item>
        <item name="qtButtonColor">@color/primary_blue</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme_App_Pink" parent="Base.Theme.QTrobot">
        <item name="qtPrimary">@color/pink_theme_text</item><!-- Near-black so all text is readable -->
        <item name="qtContainer">@color/container_pink</item>
        <item name="qtOnPrimary">@color/pink_theme_text</item>
        <item name="qtCardBackground">@color/primary_pink</item>
        <item name="qtAccent">@color/primary_pink</item>
        <item name="qtButtonColor">@color/primary_pink</item>
        <item name="colorPrimary">@color/primary_pink</item><!-- Keep buttons/switches pink -->
        <item name="android:statusBarColor">@color/primary_pink</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.QTrobot" parent="Theme_App_Blue" />

    <style name="CustomDatePickerDialog" parent="Theme.Material3.Light.Dialog">
        <item name="android:buttonBarPositiveButtonStyle">@style/DatePickerButtonStyle</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/DatePickerButtonStyle</item>
    </style>

    <style name="DatePickerButtonStyle" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@android:color/black</item>
    </style>
</resources>
